      \"spherical\" -> Lookup[allNormals[d][\"spherical\"], \"status\", \
Missing[]],
      \"spherical_sat_count\" -> Length[Lookup[allNormals[d][\"spherical\"], \
\"satellites\", {}]]
    |>],
    Keys[allNormals]
  ];
  statusSummary,
  allNormals
]\
