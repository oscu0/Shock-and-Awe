Cell[CellGroupData[{

Cell["8) Solutions Preview (Truncated)", "Section",ExpressionUUID->"2f5ddf8d-13f2-42d7-8cee-e2cc6d7587e6"],

Cell[CellGroupData[{

Cell["\<\
truncateValue[x_] := Which[
  AssociationQ[x], truncateAssoc[x],
  ListQ[x], truncateValue /@ Take[x, UpTo[5]],
  NumericQ[x], Round[N[x], 0.001],
  Head[x] === DateObject, DateString[x, {\"ISODate\", \" \", \"Time\"}],
  True, x
];

truncateAssoc[a_Association] := AssociationMap[truncateValue, \
Association@Take[Normal[a], UpTo[8]]];

previewDates = If[AssociationQ[allNormals], Take[Keys[allNormals], UpTo[3]], \
{}];

preview = AssociationMap[
  Function[d,
    <|
      \"planar\" -> KeyTake[allNormals[d][\"planar\"], {\"status\", \"triplet\
\", \"velocity_sat\", \"normal\"}],
      \"spherical\" -> KeyTake[allNormals[d][\"spherical\"], {\"status\", \
\"satellites\", \"velocity_sat\", \"objective\", \"r0\", \"sigma\"}],
      \"spherical_normals_sample\" -> \
Take[Normal@Lookup[allNormals[d][\"spherical\"], \"normals\", <||>], UpTo[3]]
    |>
  ],
  previewDates
];

truncateValue[preview]\
\>", "Input",
 CellLabel->"In[71]:=",ExpressionUUID->"cb73adcc-8bd0-4a04-92ca-f3bb9fbb372a"],

