Notebook[{

Cell[CellGroupData[{
Cell["Kinematic Normals: Planar + Spherical", "Title",ExpressionUUID->"5c02816f-fef7-485e-ae29-7c799c670c52"],

Cell["\<\
This version is split into explicit model/formula cells and implementation \
cells. It reads dates from Shocks/Shock Params.json, blacklists STEREO, \
computes planar and spherical normals, and exports JSON.\
\>", "Text",ExpressionUUID->"73d73449-6ee1-4cd7-8a62-2bff374b263f"],

Cell[CellGroupData[{

Cell["1) Setup", "Section",ExpressionUUID->"061943a5-730d-4a7d-9cb9-3946cf6a4b27"],

Cell["\<\
ClearAll[
  reKm, auKm, auOverRe, repoRootCandidates, repoRoot, shocksRoot, \
shockParamsPath, satBlacklist,
  normalizeSatName, parseDateValue, pickFirstNumeric, convertPositionUnits,
  extractPositionFromRow, extractVelocityFromRow, toAssocRows, \
extractTimestamps,
  nearestRowAtT0, nearestRowWithPosition, loadDateData, \
choosePlanarSatTriplet, chooseSphericalSatQuad, chooseVelocityVector,
  normalVector, planarNormalForDateData, sphericalNormalsForDateData,
  computeDateNormals, buildAllNormals, jsonReady, truncateValue, \
truncateAssoc
];

reKm = 6371.;
auKm = 150.*10^6;
auOverRe = auKm/reKm;
satBlacklist = {\"stereo\", \"themisc\"};

repoRootCandidates = DeleteDuplicates@Cases[{
  Quiet@Check[NotebookDirectory[], Missing[\"NoFrontEndDir\"]],
  Quiet@Check[DirectoryName[Directory[]], Missing[\"NoCwdDir\"]],
  \"/Users/aosh/Developer/Shock-and-Awe\"
}, _String];

repoRoot = SelectFirst[
  repoRootCandidates,
  FileExistsQ[FileNameJoin[{#, \"Shocks\", \"Shock Params.json\"}]] &,
  First[repoRootCandidates]
];

shocksRoot = FileNameJoin[{repoRoot, \"Data\"}];
shockParamsPath = FileNameJoin[{repoRoot, \"Shocks\", \"Shock Params.json\"}];\
\>", "Input",
 CellLabel->"In[18]:=",ExpressionUUID->"8ed1d91c-d88f-4071-9aef-e8d56cf0ac7f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2) Data Contract", "Section",ExpressionUUID->"696bb727-4870-4235-8ba3-7001a968e2ac"],

Cell["\<\
Expected shock_params shape: <| dateString -> <| sat -> <| t0, dt0_u, dt1_u, \
dt0_d, dt1_d |> |> |>.

Each per-date satellite parquet is loaded and nearest rows are selected at \
t0. If t0 row lacks coordinates, nearest row with valid coordinates is used \
for position, while velocity remains from nearest t0 row.\
\>", "Text",ExpressionUUID->"28904f41-4a5f-4172-9bf2-217adf9261a8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3) Planar Model (Explicit)", "Section",ExpressionUUID->"d333347d-fe31-4e10-a85f-360c044f971f"],

Cell["\<\
Planar kinematic model (closed-form): equations are shown below in display \
math, implementation follows.\
\>", "Text",ExpressionUUID->"5ce99e4a-d98d-49a8-9da6-99b52373069f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["t", "12"], "=", 
    FractionBox[
     RowBox[{
      SubscriptBox["t", "1"], "-", 
      SubscriptBox["t", "2"]}], 
     RowBox[{"AU", "/", 
      SubscriptBox["R", "e"]}]]}], ",", 
   RowBox[{
    SubscriptBox["t", "13"], "=", 
    FractionBox[
     RowBox[{
      SubscriptBox["t", "1"], "-", 
      SubscriptBox["t", "3"]}], 
     RowBox[{"AU", "/", 
      SubscriptBox["R", "e"]}]]}], ",", 
   RowBox[{
    RowBox[{"n", "\[CenterDot]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["r", "2"], "-", 
       SubscriptBox["r", "1"], "-", 
       RowBox[{"v", " ", 
        SubscriptBox["t", "12"]}]}], ")"}]}], "=", "0"}], ",", 
   RowBox[{
    RowBox[{"n", "\[CenterDot]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["r", "3"], "-", 
       SubscriptBox["r", "1"], "-", 
       RowBox[{"v", " ", 
        SubscriptBox["t", "13"]}]}], ")"}]}], "=", "0"}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"9c7f50bc-2d4e-47b8-\
9c70-2ef84f6a1b9a"],

Cell["\<\
normalVector[t12_, t13_, v_List, r1_List, r2_List, r3_List, nZ_: 1.] := Module[
  {aX, aY, aZ, bX, bY, bZ, cX, cY, cZ, vX, vY, vZ, nX, nY, vec, denomX, \
denomY},

  {aX, aY, aZ} = N[r1];
  {bX, bY, bZ} = N[r2];
  {cX, cY, cZ} = N[r3];
  {vX, vY, vZ} = N[v];

  denomX = ((-aX + cX - t13 vX)*(-aY + bY - t12 vY) - (-aX + bX - t12 \
vX)*(-aY + cY - t13 vY));
  denomY = (-aY*bX + aX*bY + aY*cX - bY*cX - aX*cY + bX*cY + aY t12 vX - cY \
t12 vX - aY t13 vX + bY t13 vX - aX t12 vY + cX t12 vY + aX t13 vY - bX t13 \
vY);

  If[denomX == 0 || denomY == 0, Return[Missing[\"SingularGeometry\"]]];

  nX = -((-nZ*(-aY + cY - t13 vY)*(-aZ + bZ - t12 vZ) + nZ*(-aY + bY - t12 \
vY)*(-aZ + cZ - t13 vZ))/denomX);

  nY = -((-aZ*bX*nZ + aX*bZ*nZ + aZ*cX*nZ - bZ*cX*nZ - aX*cZ*nZ + bX*cZ*nZ + \
aZ*nZ t12 vX - cZ*nZ t12 vX - aZ*nZ t13 vX + bZ*nZ t13 vX - aX*nZ t12 vZ + \
cX*nZ t12 vZ + aX*nZ t13 vZ - bX*nZ t13 vZ)/denomY);

  vec = N[{nX, nY, nZ}];
  If[!VectorQ[vec, NumericQ] || Norm[vec] == 0, Missing[\"BadNormal\"], \
Normalize[vec]]
];\
\>", "Input",
 CellLabel->"In[31]:=",ExpressionUUID->"c99be0d0-011a-44df-ac46-eb8abaafd98c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4) Spherical Model (Explicit)", "Section",ExpressionUUID->"aef32fc2-a2c1-406a-9a0c-459ffbb1a49c"],

Cell["\<\
Spherical model: fixed-radius 4-satellite construction in the co-moving frame \
(exact sphere through four advected points).\
\>", "Text",ExpressionUUID->"97731828-e383-4694-b81a-b790ff870efd"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"min", " ", 
    UnderscriptBox["\[Sum]", "i"], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{
         SubscriptBox["r", "i"], "-", 
         RowBox[{"(", 
          RowBox[{"c", "+", 
           RowBox[{"v", " ", 
            SubscriptBox["dt", "i"]}]}], ")"}]}], 
        "\[RightDoubleBracketingBar]"}], "-", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["r", "0"], "+", 
         RowBox[{"\[Sigma]", " ", 
          SubscriptBox["dt", "i"]}]}], ")"}]}], ")"}], "2"]}], ",", 
   RowBox[{
    SubscriptBox["n", "i"], "=", 
    FractionBox[
     RowBox[{
      SubscriptBox["r", "i"], "-", 
      RowBox[{"(", 
       RowBox[{"c", "+", 
        RowBox[{"v", " ", 
         SubscriptBox["dt", "i"]}]}], ")"}]}], 
     RowBox[{"\[LeftDoubleBracketingBar]", 
      RowBox[{
       SubscriptBox["r", "i"], "-", 
       RowBox[{"(", 
        RowBox[{"c", "+", 
         RowBox[{"v", " ", 
          SubscriptBox["dt", "i"]}]}], ")"}]}], 
      "\[RightDoubleBracketingBar]"}]]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"2a1f337f-3e6f-45d8-\
a4a2-88f2c925631f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5) Parsing + Row Extraction Helpers", "Section",ExpressionUUID->"d2d3f096-0716-46cf-b74c-b18b0ea83b22"],

Cell["\<\
normalizeSatName[s_String] := ToLowerCase[StringReplace[s, {\"_\" -> \"\", \
\"-\" -> \"\"}]];

parseDateValue[val_] := Module[{n, sec},
  Which[
    Head[val] === DateObject, Quiet@Check[TimeZoneConvert[val, 0], \
Missing[\"BadDate\"]],
    StringQ[val], Quiet@Check[DateObject[val, TimeZone -> 0], \
Missing[\"BadDate\"]],
    NumericQ[val],
      n = N[val];
      sec = Which[
        Abs[n] > 10^14, n/10.^9,
        Abs[n] > 10^11, n/1000.,
        True, n
      ];
      Quiet@Check[DateObject[FromUnixTime[sec, TimeZone -> 0]], \
Missing[\"BadDate\"]],
    True, Missing[\"BadDate\"]
  ]
];

pickFirstNumeric[row_Association, keys_List] := Module[{k},
  k = SelectFirst[keys, KeyExistsQ[row, #] && NumericQ[row[#]] &, \
Missing[\"NotFound\"]];
  If[MissingQ[k], Missing[\"NotFound\"], N[row[k]]]
];

convertPositionUnits[pos_List] := If[Max[Abs[pos]] > 5000, pos/reKm, pos];

extractPositionFromRow[row_Association] := Module[{x, y, z},
  x = pickFirstNumeric[row, {\"x\", \"X\", \"X_GSE\", \"x_gse\"}];
  y = pickFirstNumeric[row, {\"y\", \"Y\", \"Y_GSE\", \"y_gse\"}];
  z = pickFirstNumeric[row, {\"z\", \"Z\", \"Z_GSE\", \"z_gse\"}];
  If[AnyTrue[{x, y, z}, MissingQ], Missing[\"NoPosition\"], \
convertPositionUnits[{x, y, z}]]
];

extractVelocityFromRow[row_Association] := Module[{vx, vy, vz, v},
  vx = pickFirstNumeric[row, {\"v_x\", \"V_X_GSE\", \"vx\", \"VX\"}];
  vy = pickFirstNumeric[row, {\"v_y\", \"V_Y_GSE\", \"vy\", \"VY\"}];
  vz = pickFirstNumeric[row, {\"v_z\", \"V_Z_GSE\", \"vz\", \"VZ\"}];
  If[!AnyTrue[{vx, vy, vz}, MissingQ], Return[{vx, vy, vz}]];

  v = pickFirstNumeric[row, {\"v\", \"V\"}];
  If[MissingQ[v], Missing[\"NoVelocity\"], {-Abs[v], 0., 0.}]
];\
\>", "Input",
 CellLabel->"In[32]:=",ExpressionUUID->"98e8d587-3a28-4c8a-b17a-f1fb435df4eb"],

Cell["\<\
toAssocRows[raw_] := Module[{d = raw, keys, cols},
  d = If[Head[d] === Dataset || Head[d] === Tabular, Normal[d], d];
  Which[
    ListQ[d] && Length[d] > 0 && AssociationQ[First[d]], d,

    AssociationQ[d],
      keys = Keys[d];
      cols = Lookup[d, keys];
      If[AllTrue[cols, ListQ] && Length[Union[Length /@ cols]] == 1,
        Map[AssociationThread[keys, #] &, Transpose[cols]],
        {}
      ],

    True, {}
  ]
];

extractTimestamps[rows_List] := Module[{keys, tKey},
  If[rows === {} || !AssociationQ[First[rows]], Return[ConstantArray[Missing[\
\"NoTime\"], Length[rows]]]];
  keys = Keys[First[rows]];
  tKey = SelectFirst[{\"time\", \"Time\", \"datetime\", \"date\", \"timestamp\
\", \"Timestamp\", \"t\"}, MemberQ[keys, #] &, Missing[\"NoTimeKey\"]];
  If[MissingQ[tKey], ConstantArray[Missing[\"NoTime\"], Length[rows]], \
parseDateValue /@ Lookup[rows, tKey]]
];

nearestRowAtT0[rows_List, t0_DateObject] := Module[{ts, idx, score},
  If[rows === {}, Return[Missing[\"NoRows\"]]];
  ts = extractTimestamps[rows];
  score = Map[If[Head[#] === DateObject, Abs[AbsoluteTime[#] - \
AbsoluteTime[t0]], Infinity] &, ts];
  idx = If[Min[score] < Infinity, First@Ordering[score, 1], \
Ceiling[Length[rows]/2]];
  rows[[idx]]
];

nearestRowWithPosition[rows_List, t0_DateObject] := Module[{rowsWithPos},
  rowsWithPos = Select[rows, !MissingQ[extractPositionFromRow[#]] &];
  If[rowsWithPos === {}, Missing[\"NoPositionRows\"], \
nearestRowAtT0[rowsWithPos, t0]]
];\
\>", "Input",
 CellLabel->"In[43]:=",ExpressionUUID->"b20142d9-688f-4da3-8424-ba2e410c5820"]
}, Open  ]],

Cell[CellGroupData[{

Cell["6) Per-Date Load + Solvers", "Section",ExpressionUUID->"60e1a302-5b14-4803-a67e-819b0cc8fcef"],

Cell["\<\
loadDateData[date_String, dateParams_Association] := Module[{folder, files, \
map, sats, satData, satKey, satNorm, satParams, file, raw, rows, t0, row, \
rowPos, pos, vel},
  folder = FileNameJoin[{shocksRoot, date}];
  files = FileNames[\"*.parquet\", folder];
  map = Association[(normalizeSatName[FileBaseName[#]] -> #) & /@ files];

  sats = Keys[dateParams];
  satData = Association[];

  Do[
    satNorm = normalizeSatName[satKey];
    If[MemberQ[satBlacklist, satNorm],
      satData[satKey] = <|\"status\" -> \"blacklisted\"|>;
      Continue[];
    ];

    satParams = Lookup[dateParams, satKey, Missing[\"NoParams\"]];
    If[!AssociationQ[satParams],
      satData[satKey] = <|\"status\" -> \"no_params\"|>;
      Continue[];
    ];

    file = Lookup[map, satNorm, Missing[\"NoFile\"]];

    If[MissingQ[file],
      satData[satKey] = <|\"status\" -> \"missing_file\"|>;,

      raw = Quiet@Check[Import[file], $Failed];
      If[raw === $Failed,
        satData[satKey] = <|\"status\" -> \"import_failed\", \"file\" -> \
file|>;,

        rows = toAssocRows[raw];
        t0 = parseDateValue[Lookup[satParams, \"t0\", Missing[]]];

        If[rows === {} || Head[t0] =!= DateObject,
          satData[satKey] = <|\"status\" -> \"no_rows_or_bad_t0\", \"file\" \
-> file, \"t0\" -> t0|>;,

          row = nearestRowAtT0[rows, t0];
          rowPos = row;
          pos = extractPositionFromRow[rowPos];
          If[MissingQ[pos],
            rowPos = nearestRowWithPosition[rows, t0];
            If[Head[rowPos] === Association, pos = \
extractPositionFromRow[rowPos]];
          ];

          vel = extractVelocityFromRow[row];

          satData[satKey] = <|
            \"status\" -> \"ok\",
            \"file\" -> file,
            \"t0\" -> t0,
            \"params\" -> satParams,
            \"position\" -> pos,
            \"velocity\" -> vel,
            \"row\" -> row,
            \"row_position\" -> rowPos
          |>
        ]
      ]
    ],
    {satKey, sats}
  ];

  satData
];\
\>", "Input",
 CellLabel->"In[50]:=",ExpressionUUID->"9f8f46be-07df-45bb-89b7-cadfc215e4b7"],

Cell["\<\
choosePlanarSatTriplet[dateData_Association] := Module[{valid, \
preferredTriplets},
  valid = Select[Keys[dateData],
    KeyExistsQ[dateData[#], \"position\"] && \
VectorQ[dateData[#][\"position\"], NumericQ] && Head[Lookup[dateData[#], \"t0\
\", Missing[]]] === DateObject &
  ];

  preferredTriplets = {
    {\"ace\", \"wind\", \"dscovr\"},
    {\"ace\", \"wind\", \"mms1\"},
    {\"ace\", \"wind\", \"themis-b\"},
    {\"ace\", \"wind\", \"themis-c\"},
    {\"ace\", \"mms1\", \"wind\"},
    {\"wind\", \"themis-b\", \"themis-c\"}
  };

  SelectFirst[preferredTriplets, SubsetQ[valid, #] &, If[Length[valid] >= 3, \
Take[valid, 3], Missing[\"NoTriplet\"]]]
];

chooseSphericalSatQuad[dateData_Association] := Module[{valid, preferredQuads},
  valid = Select[Keys[dateData],
    KeyExistsQ[dateData[#], \"position\"] && \
VectorQ[dateData[#][\"position\"], NumericQ] && Head[Lookup[dateData[#], \"t0\
\", Missing[]]] === DateObject &
  ];

  preferredQuads = {
    {\"ace\", \"wind\", \"dscovr\", \"mms1\"},
    {\"ace\", \"mms1\", \"dscovr\", \"themis-b\"},
    {\"dscovr\", \"ace\", \"wind\", \"themis-b\"},
    {\"ace\", \"wind\", \"dscovr\", \"mms1\"},
    {\"ace\", \"wind\", \"dscovr\", \"soho\"}
  };

  SelectFirst[preferredQuads, SubsetQ[valid, #] &, If[Length[valid] >= 4, \
Take[valid, 4], Missing[\"NoQuad\"]]]
];

chooseVelocityVector[dateData_Association, preferred_ : {\"dscovr\", \
\"wind\", \"ace\"}] := Module[{cands, sat},
  cands = Join[preferred, Complement[Keys[dateData], preferred]];
  sat = SelectFirst[cands,
    KeyExistsQ[dateData, #] && AssociationQ[dateData[#]] && \
KeyExistsQ[dateData[#], \"velocity\"] && VectorQ[dateData[#][\"velocity\"], \
NumericQ] &,
    Missing[\"NoVelocitySat\"]
  ];
  If[MissingQ[sat], <|\"sat\" -> Missing[\"NoVelocitySat\"], \"v\" -> \
Missing[\"NoVelocity\"]|>, <|\"sat\" -> sat, \"v\" -> \
N[dateData[sat][\"velocity\"]]|>]
];\
\>", "Input",
 CellLabel->"In[51]:=",ExpressionUUID->"27458691-df8b-4194-a314-c8498b1c8d44"],

Cell["\<\
planarNormalForDateData[dateData_Association] := Module[{triad, velInfo, v, \
s1, s2, s3, t1, t2, t3, r1, r2, r3, t12, t13, n},
  triad = choosePlanarSatTriplet[dateData];
  If[MissingQ[triad], Return[<|\"status\" -> \"insufficient_satellites\"|>]];

  velInfo = chooseVelocityVector[dateData];
  If[MissingQ[velInfo[\"sat\"]] || !VectorQ[velInfo[\"v\"], NumericQ], \
Return[<|\"status\" -> \"no_velocity\", \"triplet\" -> triad|>]];

  {s1, s2, s3} = triad;
  t1 = dateData[s1][\"t0\"];
  t2 = dateData[s2][\"t0\"];
  t3 = dateData[s3][\"t0\"];

  r1 = dateData[s1][\"position\"];
  r2 = dateData[s2][\"position\"];
  r3 = dateData[s3][\"position\"];

  t12 = (AbsoluteTime[t1] - AbsoluteTime[t2])/auOverRe;
  t13 = (AbsoluteTime[t1] - AbsoluteTime[t3])/auOverRe;

  v = velInfo[\"v\"];
  n = normalVector[t12, t13, v, r1, r2, r3];

  If[MissingQ[n], <|\"status\" -> \"failed\", \"triplet\" -> triad, \
\"velocity_sat\" -> velInfo[\"sat\"]|>,
    <|
      \"status\" -> \"ok\",
      \"triplet\" -> triad,
      \"velocity_sat\" -> velInfo[\"sat\"],
      \"velocity\" -> v,
      \"normal\" -> n
    |>
  ]
];\
\>", "Input",
 CellLabel->"In[56]:=",ExpressionUUID->"a7d5047c-237b-4902-a6d4-3a73fef37c14"],

Cell["\<\
sphericalNormalsForDateData[dateData_Association] := Module[{validSats, quad, \
velInfo, timeRefSat, v, dt, pos, advectedPos, p1, p2, p3, p4, mat, rhs, \
center, sigma, r0, normals},
  validSats = Select[Keys[dateData],
    KeyExistsQ[dateData[#], \"position\"] && \
VectorQ[dateData[#][\"position\"], NumericQ] && Head[Lookup[dateData[#], \"t0\
\", Missing[]]] === DateObject &
  ];

  quad = chooseSphericalSatQuad[dateData];
  If[MissingQ[quad], Return[<|\"status\" -> \"insufficient_satellites\", \
\"satellites\" -> validSats|>]];

  velInfo = chooseVelocityVector[dateData, {\"dscovr\", \"wind\", \"ace\", \
\"themis-b\"}];
  If[MissingQ[velInfo[\"sat\"]] || !VectorQ[velInfo[\"v\"], NumericQ], \
Return[<|\"status\" -> \"no_velocity\", \"satellites\" -> quad|>]];

  timeRefSat = First @ MinimalBy[quad, AbsoluteTime[dateData[#][\"t0\"]] &];
  v = N[velInfo[\"v\"]];

  dt = AssociationMap[(AbsoluteTime[dateData[#][\"t0\"]] - \
AbsoluteTime[dateData[timeRefSat][\"t0\"]]) / auOverRe &, quad];
  pos = AssociationMap[N[dateData[#][\"position\"]] &, quad];
  advectedPos = AssociationMap[pos[#] - v dt[#] &, quad];

  {p1, p2, p3, p4} = advectedPos /@ quad;
  mat = 2 {
    p1 - p2,
    p1 - p3,
    p1 - p4
  };
  rhs = {
    p1 . p1 - p2 . p2,
    p1 . p1 - p3 . p3,
    p1 . p1 - p4 . p4
  };

  If[Abs[Det[mat]] < 10^-10,
    Return[<|\"status\" -> \"singular_geometry\", \"satellites\" -> quad, \
\"velocity_sat\" -> velInfo[\"sat\"], \"reference_sat\" -> timeRefSat|>]
  ];

  center = N[LinearSolve[mat, rhs]];
  sigma = N[Norm[p1 - center]^2];
  r0 = N[Sqrt[sigma]];

  If[!NumericQ[sigma] || sigma <= 0,
    Return[<|\"status\" -> \"fit_failed\", \"satellites\" -> quad, \
\"velocity_sat\" -> velInfo[\"sat\"], \"reference_sat\" -> timeRefSat|>]
  ];

  normals = AssociationMap[
    Normalize[pos[#] - (center + v dt[#])] &,
    quad
  ];

  <|
    \"status\" -> \"ok\",
    \"method\" -> \"fixed_radius_4sat\",
    \"velocity_sat\" -> velInfo[\"sat\"],
    \"reference_sat\" -> timeRefSat,
    \"velocity\" -> v,
    \"satellites\" -> quad,
    \"center\" -> center,
    \"r0\" -> r0,
    \"sigma\" -> sigma,
    \"normals\" -> normals
  |>
];\
\>", "Input",
 CellLabel->"In[57]:=",ExpressionUUID->"25c9f77a-a42a-4013-9724-8b7d4dfb904e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["7) Run All Dates + Export", "Section",ExpressionUUID->"16cefe35-4489-4c0e-acbc-a9f72d5e74c2"],

Cell[CellGroupData[{

Cell["\<\
computeDateNormals[date_String, params_Association] := Module[{dateData, \
planar, spherical},
  dateData = loadDateData[date, params[date]];
  planar = planarNormalForDateData[dateData];
  spherical = sphericalNormalsForDateData[dateData];
  <|\"planar\" -> planar, \"spherical\" -> spherical|>
];

buildAllNormals[] := Module[{params, dates},
  params = Import[shockParamsPath, \"RawJSON\"];
  If[!AssociationQ[params], Return[$Failed]];
  dates = Sort[Keys[params]];
  AssociationMap[computeDateNormals[#, params] &, dates]
];

jsonReady[x_] := Which[
  AssociationQ[x], AssociationMap[jsonReady, x],
  ListQ[x], jsonReady /@ x,
  Head[x] === DateObject, DateString[x, {\"ISODate\", \" \", \"Time\"}],
  Head[x] === Missing, Null,
  NumericQ[x], N[x],
  True, x
];

allNormals = buildAllNormals[];

If[allNormals === $Failed,
  Print[\"Failed to load shock parameters from: \" <> shockParamsPath],
  Print[\"Computed dates: \" <> ToString[Length[Keys[allNormals]]]]
];

outputPath = FileNameJoin[{repoRoot, \"Shocks\", \"Kinematic Shock \
Normals (Wolfram).json\"}];
Export[outputPath, jsonReady[allNormals], \"RawJSON\"];
Print[\"Exported: \" <> outputPath];\
\>", "Input",
