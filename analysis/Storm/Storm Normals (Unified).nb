Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"2022-01-16 19-09-00\"\>", "\[Rule]", 
    RowBox[{"\[LeftAssociation]", 
     RowBox[{
      RowBox[{"\<\"planar\"\>", "\[Rule]", 
       RowBox[{"\[LeftAssociation]", 
        RowBox[{
         RowBox[{"\<\"status\"\>", "\[Rule]", "\<\"ok\"\>"}], ",", 
         RowBox[{"\<\"triplet\"\>", "\[Rule]", 
          RowBox[{"{", 
           
           RowBox[{"\<\"ace\"\>", ",", "\<\"mms1\"\>", 
            ",", "\<\"dscovr\"\>"}], "}"}]}], ",", 
         RowBox[{"\<\"velocity_sat\"\>", "\[Rule]", "\<\"dscovr\"\>"}], ",", 
         RowBox[{"\<\"velocity\"\>", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "557.5`"}], ",", "35.400001525878906`", ",", 
            RowBox[{"-", "22.399999618530273`"}]}], "}"}]}], ",", 
         RowBox[{"\<\"normal\"\>", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.951199559225228`"}], ",", 
            RowBox[{"-", "0.08345797074604147`"}], ",", 
            "0.29707602671485484`"}], "}"}]}]}], "\[RightAssociation]"}]}], ",", 
      RowBox[{"\<\"spherical\"\>", "\[Rule]", 
       RowBox[{"\[LeftAssociation]", 
        RowBox[{
